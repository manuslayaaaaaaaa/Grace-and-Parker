"border_thickness":0,"section_radius":0,"lazy":true}},"testimonials_slider_dKBxHe":{"type":"testimonials-slider","disabled":true,"name":"Testimonial Grid","settings":{}},"text_and_image_Fz6EK9":{"type":"text-and-image","name":"t:sections.text-and-image.presets.image_with_text.name","settings":{"image":"shopify:\/\/shop_images\/ChatGPT_Image_31_jan_2026_17_03_13.png","image_mask":"rounded-top","image2_mask":"none","subtitle":"","title":"Eine persönliche Nachricht von Claudia","text":"<p>Vor 25 Jahren begann unsere Boutique als Herzensprojekt von Mutter und Tochter, <br\/>getragen von der Idee, Mode mit Ruhe, Qualität und Bedeutung anzubieten.<\/p><p>Stücke, die nicht Trends folgen, sondern begleiten.<br\/>Unaufdringlich, zeitlos und bewusst gewählt.<\/p><p>Heute schließen wir dieses Kapitel mit Dankbarkeit<br\/>und nehmen nach 25 gemeinsamen Jahren bewusst Abschied.<\/p><p>Mit Herz 🤍<br\/><strong>Claudia & Monika<\/strong><\/p>","button_label":"","button_link":"","button_style":"primary","align_text":"left","image_width":"50","layout":"right","divider":false,"top_padding":true,"bottom_padding":true,"lazyload_images":true}},"advanced_content_rQtHGM":{"type":"advanced-content","blocks":{"image_raTfgL":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/Eigenaren2.png","link":"","width":"50%","alignment":"center"}},"liquid_yeGTF4":{"type":"liquid","settings":{"code":"<h2>Mit Liebe ausgewählt ♥<\/h2>\n<p>\nJedes Stück bei Claudia & Monika Zürich wird mit Sorgfalt und einem geschulten Blick ausgewählt. Unsere Arbeit ist geprägt von einem Sinn für zeitlose Eleganz, Tragekomfort und Qualität — Werte, die wir seit vielen Jahren bewusst pflegen.\n<\/p>\n<p>\n  Inspiriert von der engen Verbindung zwischen Mutter und Tochter steht unsere Kollektion für Kleidung, die Frauen begleitet: im Alltag, in besonderen Momenten und in Phasen des Wandels. Stücke, die sich gut anfühlen und Raum lassen, ganz man selbst zu sein.\n<\/p>","width":"50%","alignment":"center"}}},"block_order":["image_raTfgL","liquid_yeGTF4"],"disabled":true,"name":"t:sections.advanced-content.presets.custom_content.name","settings":{"full_width":false,"space_around":true,"lazyload_images":true}},"sub":{"type":"product-full-width","disabled":true,"settings":{"max_width":true}},"product-recommendations":{"type":"product-recommendations","disabled":true,"settings":{"product_recommendations_heading":"You may also like","related_count":6,"products_per_row":3}},"recently-viewed":{"type":"recently-viewed","disabled":true,"settings":{"recent_count":5}},"collection-return":{"type":"collection-return","disabled":true,"settings":{}},"faq_N9hAPP":{"type":"faq","blocks":{"question_hyVHpU":{"type":"question","settings":{"title":"Wie kann ich sicherstellen, dass mir der Artikel richtig passt?","text":"<p>Auf jeder Produktseite finden Sie eine <strong>detaillierte Größentabelle<\/strong>, die Ihnen hilft, die passende Größe zu finden. Wir empfehlen, die Angaben mit einem ähnlichen Kleidungsstück zu vergleichen, das Sie bereits besitzen.<\/p><p>Wenn Sie zwischen zwei Größen liegen, empfehlen wir in der Regel, die <strong>größere Größe<\/strong> zu wählen, um einen möglichst angenehmen Tragekomfort zu gewährleisten.<br\/><br\/>Sind Sie unsicher? Unser Kundenservice hilft Ihnen gerne bei der Wahl der richtigen Größe!<\/p>"}},"question_t4YJcY":{"type":"question","settings":{"title":"Wie lange dauert der Versand?","text":"<p>Bestellungen werden in der Regel <strong>innerhalb von 3 Werktagen<\/strong> nach Aufgabe der Bestellung bearbeitet.<\/p>"}},"question_gXfXEb":{"type":"question","settings":{"title":"Wie kann ich meine Bestellung verfolgen?","text":"<p>Sobald Ihre Bestellung bestätigt wurde, erhalten Sie eine E-Mail mit Ihrer Bestellnummer.<br\/><br\/>Um Ihre Bestellung zu verfolgen, besuchen Sie einfach unsere <a href=\"\/apps\/parcelpanel\" title=\"\/apps\/parcelpanel\"><strong>Bestellverfolgungsseite<\/strong><\/a> und geben Sie Ihre Bestellnummer oder E-Mail-Adresse ein.<\/p>"}},"question_t4YRrf":{"type":"question","settings":{"title":"Wie lautet das Rückgaberecht?","text":"<p>Sie können Artikel <strong>innerhalb von 30 Kalendertagen nach Erhalt<\/strong> zurücksenden.<\/p><ul><li>Die <strong>Kosten für die Rücksendung<\/strong> trägt der Käufer.<\/li><li>Genehmigte Rückerstattungen werden über das <strong>ursprünglich verwendete Zahlungsmittel<\/strong> ausgezahlt.<\/li><\/ul><p>Weitere Informationen finden Sie in unserer <a href=\"\/pages\/ruckgaberecht\" title=\"Rückgaberecht\"><strong>Rückgaberichtlinie<\/strong><\/a>.<\/p>"}},"question_fTgniy":{"type":"question","settings":{"title":"Ich habe ein Problem mit meiner Bestellung. Wie kann ich Sie kontaktieren?","text":"<p>Wenn Sie Fragen haben oder ein Problem aufgetreten ist, besuchen Sie bitte unsere <a href=\"\/pages\/kontakt\" title=\"Kontakt\"><strong>Kontaktseite<\/strong><\/a>, um mit unserem Support-Team in Verbindung zu treten.<br\/><br\/>Wir helfen Ihnen gerne und zeitnah weiter.<\/p>"}}},"block_order":["question_hyVHpU","question_t4YJcY","question_gXfXEb","question_t4YRrf","question_fTgniy"],"name":"t:sections.faq.presets.faq.name","settings":{"title":"FAQs"}},"testimonials_XJpjRp":{"type":"testimonials","blocks":{"testimonial_teRGdf":{"type":"testimonial","settings":{"icon":"5-stars","testimonial":"<p>The item fits as promised and the fabric is wonderfully comfortable.<\/p>","author":"Anna O.","author_info":"New York, United States"}},"testimonial_F4NqaY":{"type":"testimonial","settings":{"icon":"4-stars","testimonial":"<p>Very satisfied with the purchase. Timeless style and great quality.<\/p>","author":"Sarah A.","author_info":"Chicago, United States"}},"testimonial_3PPQAF":{"type":"testimonial","settings":{"icon":"5-stars","testimonial":"<p>The clothes are sturdy and exude elegance. Exactly what I was looking for.<\/p>","author":"Emma T.","author_info":"Miami, United States"}},"testimonial_BDq4BM":{"type":"testimonial","settings":{"icon":"5-stars","testimonial":"<p>Great quality and perfect fit! I would definitely recommend.<\/p>","author":"Isabelle A.","author_info":"Houston, United States"}},"testimonial_XUFz4P":{"type":"testimonial","settings":{"icon":"5-stars","testimonial":"<p>It fits perfectly and looks great. Completely satisfied.<\/p>","author":"Lisa S","author_info":"Los Angeles, United States"}}},"block_order":["testimonial_teRGdf","testimonial_F4NqaY","testimonial_3PPQAF","testimonial_BDq4BM","testimonial_XUFz4P"],"disabled":true,"settings":{"title":"What customers have to say about Austin Boutique","align_text":"center","round_images":true,"color_background":"#ffffff","color_text":"#1c1d1d"}},"text_with_icons_Q8WN8G":{"type":"text-with-icons","blocks":{"text_block_PXYphH":{"type":"text_block","settings":{"icon":"calendar","title":"30-TAGE-GELD-ZURÜCK-GARANTIE","text":"<p>Wir bieten ein <strong>30-tägiges Rückgaberecht<\/strong> an.<br\/>Sie können jeden Artikel <strong>innerhalb von 30 Tagen<\/strong> zurücksenden, wenn Sie nicht vollständig zufrieden sind.<\/p>"}},"text_block_haGEYF":{"type":"text_block","settings":{"icon":"chat","title":"24\/7 KUNDENSERVICE","text":"<p>Wenn Sie Fragen, Feedback oder Anliegen zu Ihrer Bestellung haben, machen Sie sich keine Sorgen. Unser Kundenservice-Team steht Ihnen jederzeit gerne zur Verfügung.<\/p>"}},"text_block_f3GT7y":{"type":"text_block","settings":{"icon":"truck","title":"KOSTENLOSE LIEFERUNG","text":"<p>Wir bieten <strong>kostenlosen Versand <\/strong>inklusive<strong> Track & Trace <\/strong>innerhalb der Schweiz an.<\/p>"}},"text_block_pgeXmX":{"type":"text_block","settings":{"icon":"shield","title":"SICHERE ZAHLUNG","text":"<p>Ihre Zahlungsinformationen werden <strong>sicher verarbeitet<\/strong>.<\/p>"}}},"block_order":["text_block_PXYphH","text_block_haGEYF","text_block_f3GT7y","text_block_pgeXmX"],"settings":{"title":"","align_text":"center","desktop_columns_per_row":4,"icon_color":"#000000","button_label":"","button_link":"","divider":false}},"1759238496adc47e65":{"type